generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  notes              Note[]
  tags               Tag[]
  settings           UserSettings?
  driveCredential    DriveCredential?
  calendarCredential CalendarCredential?
  resetTokens        PasswordResetToken[]
  projects           Project[]
  templates          NoteTemplate[]
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  anthropicApiKey String?
  syncProvider    String? // "google_drive" | "onedrive" | "dropbox" | null
  syncInterval    String  @default("manual") // "manual" | "5min" | "15min" | "30min" | "1hr"
  theme           String  @default("system")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("")
  content   String   @default("")
  color     String   @default("default")
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  type      String   @default("text") // text | checklist
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parentId         String?
  locked           Boolean  @default(false)
  lockPasswordHash String?
  deletedAt        DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags           TagsOnNotes[]
  reminders      Reminder[]
  checklistItems ChecklistItem[]
  attachments    NoteAttachment[]
  driveSync      DriveSync?
  projects       ProjectNote[]
  parent         Note?           @relation("NoteChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Note[]          @relation("NoteChildren")
}

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("gray")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes TagsOnNotes[]

  @@unique([userId, name])
}

model TagsOnNotes {
  noteId String
  tagId  String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model Reminder {
  id              String   @id @default(cuid())
  noteId          String
  datetime        DateTime
  recurring       String   @default("none") // none | daily | weekly | monthly
  status          String   @default("pending") // pending | triggered | dismissed
  calendarEventId String?

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model ChecklistItem {
  id      String  @id @default(cuid())
  noteId  String
  text    String
  checked Boolean @default(false)
  order   Int     @default(0)

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  type      String   // "photo" | "voice"
  url       String
  filename  String
  mimeType  String
  sizeBytes Int      @default(0)
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model DriveCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriveSync {
  id           String   @id @default(cuid())
  noteId       String   @unique
  driveFileId  String
  lastSyncedAt DateTime

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  color       String   @default("blue")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes ProjectNote[]

  @@unique([userId, name])
}

model NoteTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   String   @default("")
  type      String   @default("text")
  color     String   @default("default")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectNote {
  projectId String
  noteId    String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  note    Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([projectId, noteId])
}
